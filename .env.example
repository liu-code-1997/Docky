# 复制为 .env 可覆盖默认配置(可选)
# OLLAMA_BASE_URL=http://localhost:11434
# QDRANT_URL=http://localhost:6333
# LLM_MODEL=qwen2.5:7b
# EMBEDDING_MODEL=nomic-embed-text
# CHUNK_SIZE=800
# CHUNK_OVERLAP=150
# CHUNK_STRATEGY=char   # M5①切分策略:char(baseline) | markdown(按标题+噪声过滤,改后需重新 ingest)
# QUERY_REWRITE=true    # M5②检索前用 LLM 扩展英文术语(缓解跨语言检索)。默认开(消融验证最有效);设 false 可关
# RERANK=false          # M5③检索后用 LLM 重排候选,会多 top_k×RERANK_FACTOR 次 LLM 调用(慢)
# RERANK_FACTOR=5       # 重排时召回 top_k×该倍数 个候选
# TOP_K=4
# EVAL_SCORER=keyword   # M4 生成层评分:keyword | llm_judge | semantic
# LLM_TEMPERATURE=0.7   # 日常问答生成温度(略高更自然)
# EVAL_TEMPERATURE=0.0  # 评估时温度(恒 0,保证结果可复现)
